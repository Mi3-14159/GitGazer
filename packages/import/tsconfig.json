{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["es2021", "dom"],
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2020",
    "types": ["node"]
  },
  "exclude": ["node_modules/**/*", "dist/**/*"],
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}
