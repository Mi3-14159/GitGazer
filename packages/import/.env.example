# GitGazer API
API_URL=https://app.gitgazer.com
INTEGRATION_ID=your-integration-uuid
INTEGRATION_SECRET=your-integration-secret

# GitHub API
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_OWNER=your-org

# Repository selection (pick one mode):
# Single repo mode:
# GITHUB_REPO=my-repo
# Org discovery with topic filter:
# GITHUB_TOPIC=production
# Leave both empty to import all active org repos

# Optional: date range (ISO date strings)
# SINCE=2025-01-01
# UNTIL=2025-12-31

# Optional: preview without sending data
# DRY_RUN=true

# Optional: event types to import (default: all)
# EVENT_TYPES=workflow_run,workflow_job,pull_request,pull_request_review

# Optional: parallel processing (default: 1)
# CONCURRENCY=10
