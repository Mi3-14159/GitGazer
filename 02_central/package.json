    "@aws-sdk/client-firehose": "^3.1002.0",
    "@aws-sdk/client-glue": "^3.1002.0",
    "@aws-sdk/client-iam": "^3.1002.0",
    "@aws-sdk/client-lakeformation": "^3.1002.0",
    "@aws-sdk/client-rds-data": "3.873.0",
    "@aws-sdk/client-s3": "^3.1002.0",
    "@aws-sdk/client-sts": "^3.1002.0",
    "@aws-sdk/s3-request-presigner": "^3.1002.0",
    "@octokit/webhooks": "^14.2.0",
    "@octokit/webhooks-schemas": "^7.6.1",
    "@octokit/webhooks-types": "^7.6.1",
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^24.10.13",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.45.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "aws-jwt-verify": "^5.1.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "eslint": "^9.39.2",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "^24"
  },
  "homepage": "https://github.com/Mi3-14159/GitGazer#readme",
  "keywords": [],
  "name": "@gitgazer/lambdas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mi3-14159/GitGazer.git"
  },
  "scripts": {
    "build": "rimraf dist && tsup",
    "buildZip": "pnpm run build && pnpm run zip:api && pnpm run zip:websocket",
    "buildZip:api": "pnpm run build && pnpm run zip:api",
    "buildZip:websocket": "pnpm run build && pnpm run zip:websocket",
    "clean": "rimraf dist tmp",
    "dev:api": "node --env-file=.env.dev --watch -r ts-node/register src/develop.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "pretty": "prettier --write src",
    "test:unit": "vitest --project unit --run",
    "zip:api": "cd dist/api && zip gitgazer-api.zip -qr * && mkdir -p ../../tmp && mv gitgazer-api.zip ../../tmp/",
    "zip:websocket": "cd dist/websocket && zip gitgazer-websocket.zip -qr * && mkdir -p ../../tmp && mv gitgazer-websocket.zip ../../tmp/"
  },
  "version": "1.0.0"
}